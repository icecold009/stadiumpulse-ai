NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

FIREWORKS_API_KEY=
FIREWORKS_RECOMMENDATION_MODEL=accounts/fireworks/models/deepseek-v4-pro

# Optional public judge demo. Uses fixed existing accounts; no password is exposed.
DEMO_ACCESS_ENABLED=false
DEMO_ADMIN_EMAIL=
DEMO_OPS_MANAGER_EMAIL=
DEMO_SUSTAINABILITY_LEAD_EMAIL=
DEMO_VOLUNTEER_COORDINATOR_EMAIL=
